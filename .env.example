# ─── Discord ──────────────────────────────────────────────────────────────────
# Webhook URL do canal onde os alertas vão cair.
# Como criar: Discord → canal → Editar Canal → Integrações → Webhooks → Novo Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_ID/SEU_TOKEN

# Se true, envia mensagem "tudo OK" a cada ciclo mesmo sem problemas.
# Deixe false para só receber alertas de erro (recomendado).
DISCORD_NOTIFY_OK=false

# ─── Segurança ────────────────────────────────────────────────────────────────
# Secret para proteger /api/check de chamadas externas não autorizadas.
# Pode ser qualquer string aleatória. Vercel Cron usa automaticamente.
# Gere um: openssl rand -hex 32
CRON_SECRET=troque_por_uma_string_aleatoria_segura
